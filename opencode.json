{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode_omnirouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRoute via opencode (spike, isolado do provider omnirouter real que usa openclaude)",
      "options": {
        "baseURL": "https://omni.workflowapi.com.br/v1",
        "apiKey": "{env:OMNIROUTE_SPIKE_API_KEY}"
      },
      "models": {
        "auto": {
          "name": "OmniRoute auto (LKGP)"
        },
        "auto/coding": {
          "name": "OmniRoute auto/coding"
        },
        "xai/grok-4.3": {
          "name": "xAI Grok 4.3 via OmniRoute (teste de custo metrificado, nao-assinatura)"
        }
      }
    }
  },
  "agent": {
    "build": {
      "steps": 15
    }
  }
}
